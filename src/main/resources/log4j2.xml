<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="com.spribe.listeners">

    <Appenders>

        <!-- Console -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <!-- File -->
        <File name="File" fileName="target/logs/automation.log" append="true">
            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </File>

        <!-- Allure Log Appender -->
        <AllureLogAppender name="AllureAppender">
            <PatternLayout
                    pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </AllureLogAppender>

    </Appenders>

    <Loggers>

        <!-- Reduce noise from RestAssured internals -->
        <Logger name="io.restassured" level="warn"/>
        <Logger name="org.apache.http" level="warn"/>

        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
            <AppenderRef ref="AllureAppender"/>
        </Root>

    </Loggers>
</Configuration>